# Cloud-safe env for research/notify/journal routines.
# No MT5 credentials — order execution stays on the local Windows box.
#
# For GitHub Actions: populate these as repo secrets (Settings → Secrets → Actions)
#   PERPLEXITY_API_KEY, DISCORD_WEBHOOK_URL
# For Claude Desktop cloud routines: set as per-routine env vars in the UI.
# Do NOT commit this file with real values — `.env.cloud` is gitignored.

# ---------- Stage / broker ----------
# Cloud never places real orders. Force mock broker + dev stage as a belt-and-braces.
TRADING_STAGE=dev
BROKER_MODE=mock

# ---------- Research (Perplexity) ----------
PERPLEXITY_API_KEY=

# ---------- Notifications (Discord) ----------
DISCORD_WEBHOOK_URL=

# ---------- Display timezone ----------
DISPLAY_TIMEZONE=America/New_York
