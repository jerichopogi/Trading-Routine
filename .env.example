# ---------- Stage ----------
# dev | demo | challenge | funded
# Start in dev (MockBroker, no real orders) on Mac.
# Flip to demo on Windows after MT5 is wired up.
TRADING_STAGE=dev

# ---------- Broker ----------
# mock | mt5
# mock:  MockBroker (Mac dev, CI)
# mt5:   real MetaTrader 5 terminal (Windows only)
BROKER_MODE=mock

# MT5 login details (ignored when BROKER_MODE=mock)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=FundedNext-Demo
# Optional: path to terminal64.exe if not on PATH
MT5_TERMINAL_PATH=

# ---------- Research ----------
PERPLEXITY_API_KEY=

# ---------- Notifications ----------
DISCORD_WEBHOOK_URL=

# ---------- Paths ----------
# Leave empty to use repo-relative defaults.
MEMORY_DIR=
CONFIG_DIR=

# ---------- Safety ----------
# Set to 1 to allow real orders. Defaults to 0 (dry-run) unless explicitly enabled.
ALLOW_LIVE_ORDERS=0
